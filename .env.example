DATABASE_URL=$DATABASE_URL

# Base network RPC endpoint (WebSocket)
# Requires RPC provider that supports debug_traceTransaction for Pyth price extraction
# Recommended: dRPC (https://drpc.org/) - Free tier: 210M compute units/month
# Format: wss://lb.drpc.org/base/API_KEY
WS_RPC_URL=$WS_RPC_URL

ORDERBOOK=$ORDERBOOK
ORDER_OWNER=$ORDER_OWNER
DEPLOYMENT_BLOCK=$DEPLOYMENT_BLOCK
APP_KEY=$APP_KEY
APP_SECRET=$APP_SECRET
RUST_LOG=$RUST_LOG

# Optional: OTLP endpoint for metrics (omit to disable metrics)
# For Docker Compose with Grafana:
# OTEL_METRICS_EXPORTER_ENDPOINT=http://grafana:4318
# For local development: omit this variable to run without metrics

# Grafana admin password (change this in production!)
GRAFANA_ADMIN_PASSWORD=$GRAFANA_ADMIN_PASSWORD
